{
    "name": "jsm-games-web",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "theme-words:sync-letters": "node src/games/theme-words/scripts/sync-reversed-letter-seed.mjs --write --from 2021-04-20 --to 2046-04-20",
        "theme-words:generate-themes": "node src/games/theme-words/scripts/generate-themed-seed.mjs --write",
        "theme-words:layout": "node src/games/theme-words/scripts/generate-crossword-layout.mjs --write --restarts 120 --budget-ms 20000",
        "typecheck": "tsc --noEmit",
        "lint": "echo \"No linter configured yet\"",
        "format": "echo \"No formatter configured yet\"",
        "test": "echo \"No tests configured yet\"",
        "ci": "npm run typecheck && npm run build && npm run test"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.57.4",
        "qrcode": "^1.5.4",
        "react": "^19.1.1",
        "react-dom": "^19.1.1"
    },
    "devDependencies": {
        "@types/qrcode": "^1.5.6",
        "@types/react": "^19.1.10",
        "@types/react-dom": "^19.1.7",
        "@vitejs/plugin-react": "^6.0.1",
        "typescript": "^5.9.2",
        "vite": "^8.0.7"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
